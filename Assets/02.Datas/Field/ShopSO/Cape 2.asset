  m_Script: {fileID: 11500000, guid: 53a271983285ce0499ac617374539b78, type: 3}
  m_Name: Cape 2
  m_EditorClassIdentifier: Assembly-CSharp::ShopSO
  NPCName: "\uCF00\uC774\uD5042"
  Npc: 4
  dialogue:
  - "\uC774\uC804 \uC139\uD130\uB294 \"\uC624\uAC70 \uC7AD\"\uC774 \uB9C9\uACE0 \uC788\uC73C\uB2C8\\n\uAE08\uBC29
    \uC8FD\uC9C0 \uC54A\uC744\uAE4C \uD588\uB294\uB370."
  - ...
  - "...\uC801\uB2F9\uD788 \uCF00\uC774\uD504\uB77C\uACE0 \uBD88\uB7EC."
  - "\uC6A9\uCF00\uB3C4 \uACC4\uC18D \uAC00\uB294\uAD6C\uB098."
  - "\uBD88\uD3B8\uD55C \uAC83 \uBC16\uC5D0 \uC5C6\uB294 \uB3D9\uB124\uC57C.\\n\uC544\uB9C8
    \uC678\uC9C0\uC778\uC778 \uB124\uAC00 \uCCB4\uAC10\uC774 \uD06C\uACA0\uC9C0."
  - "\uADF8\uB7FC \uC65C \uC548 \uB5A0\uB098\uB0D0\uACE0?"
  - ...
  - "...\uADF8\uB798\uB3C4 \uB0B4\uAC00 \uB098\uACE0 \uC790\uB780 \uACF3\uC774\uC57C."
  - "\uC2DC\uBBAC\uB7EC\uD55C\uD14C\uB3C4 \uBE44\uC2B7\uD55C \uAC10\uC815\uC774 \uC788\uC744\uC9C4
    \uBAA8\uB974\uACA0\uB124."
  - "\uC2E4\uD5D8\uC2E4\uC5D0\uC11C \uD0DC\uC5B4\uB098\uC11C \uC2F8\uC6B0\uB2E4 \uC8FD\uB294
    \uC874\uC7AC\uC796\uC544."
  - ...
  - "...\uC544\uB2C8\uB77C\uACE0?"
  - ...
  - ......
  - .........
  - "\uADF8\uB798, \uBBF8\uC548. \uB0B4\uAC00 \uC0DD\uAC01\uC774 \uC880 \uC9E7\uC558\uB124."
  - "\uB9D0\uD588\uC796\uC544. \uB09C \uB9D0\uC8FC\uBCC0\uC774 \uC5C6\uB2E4\uACE0."
  - ...
  - "\uADF8\uB7FC \uC2DC\uBBAC\uB7EC \uB10C \uACE0\uD5A5\uC774 \uC788\uC5B4?"
  - "\uC544\uB0D0, \uC78A\uC5B4. \uAD1C\uD55C \uAC78 \uBB3C\uC5C8\uB124."
  - "\uADF8\uB798\uC11C, \uC0B4 \uAC70\uC57C \uB9D0 \uAC70\uC57C?"
  gambling:
  - "\uD589\uC6B4\uC744 \uBE4C\uAC8C. \uBBF8\uC548\uD558\uC9C0\uB9CC\\n\uC774\uACF3
    \uB8F0\uC774\uB77C\uC11C \uB9D0\uC774\uC57C."
  repair:
  - "\uC6B0\uC8FC\uC120\uC744 \uD5D8\uD558\uAC8C \uB2E4\uB8E8\uB124.\\n\uC5B4\uCC28\uD53C
    \uBCF8\uCCB4\uB294 \uC6B0\uC8FC\uC120 \uC544\uB2C8\uC57C?"
  firstshops:
  - "\uBB50\uC57C, \uC2DC\uBBAC\uB7EC\uC796\uC544. \uC0B4\uC544 \uC788\uC5C8\uB0D0?"
  buyScrap:
  - "\uC2DC\uBBAC\uB7EC\uB4E4\uC740 \uBB58 \uB9CC\uB4E4 \uBAB8\uB3C4 \uC5C6\uC73C\uBA74\uC11C
    \uD56D\uC0C1 \uB69D\uB531 \uC798 \uB9CC\uB4E4\uC5B4\uB0B8\uB2E8 \uB9D0\uC774\uC9C0."
