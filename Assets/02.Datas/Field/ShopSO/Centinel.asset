%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 53a271983285ce0499ac617374539b78, type: 3}
  m_Name: Centinel
  m_EditorClassIdentifier: Assembly-CSharp::ShopSO
  NPCName: "\uC13C\uD2F0\uB12C"
  Npc: 3
  dialogue:
  - "\uC81C\uAD6D \uC784\uC2DC \uBCF4\uAE09\uAD00\\n\uC13C\uD2F0\uB12C\uC774\uC608\uC694."
  - "\uBA3C\uC800 \uB9D0\uC744 \uAC70\uB294 \uC2DC\uBBAC\uB7EC\uB77C\uB2C8.\\n\uC7AC\uBC0C\uB124\uC694."
  - "\uAD1C\uCC2E\uC544\uC694. \uB300\uD654 \uC88B\uC544\uD558\uB2C8\uAE4C.\\n\uD2B9\uD788
    \uAC19\uC740 \uAC1C\uC870 \uC778\uAC04\uC774\uB77C\uBA74."
  - "\uB2F9\uC2E0\uC740 \uB1CC\uB9CC \uB0A8\uC558\uACE0,\\n\uC800\uB294 \uBAB8\uC758
    \uC77C\uBD80\uB9CC \uB0A8\uC558\uB2E4\uB294\\n\uCC28\uC774\uAC00 \uC788\uC9C0\uB9CC\\n\uC9C4\uD654
    \uC778\uB958\uB85C\uC11C \uC874\uC911\uD574\uC694."
  - "\uB9BC\uBCF4 \uCABD \uC6D0\uC2DC\uC778\uC774\uB098\\n\uBC1C\uCE78 \uAC19\uC740
    \uD1F4\uD654 \uBCF4\uB2E4\uB294 \uB0AB\uC796\uC544\uC694?"
  - "\uB808\uD14C\uB97C \uB178\uB9AC\uB098\uC694?\\n\uC624\uC5FC\uC774\uB098 \uCE68\uC2DD
    \uC5C6\uC774\\n\uC811\uADFC\uD560 \uC218 \uC788\uB294 \uAC74\\n\uC624\uB85C\uC9C0
    \uC2DC\uBBAC\uB7EC\uB2C8\uAE4C."
  - "\uBB50, \uC54C\uACE0 \uC788\uC73C\uB2C8\uAE4C\\n\uC774\uB7F0 \uC678\uC9C4 \uBD84\uC7C1
    \uAD6C\uC5ED\uAE4C\uC9C0\\n\uCE68\uC785 \uD588\uACA0\uC8E0?"
  - "\uD558\uC9C0\uB9CC \uC27D\uC9C0 \uC54A\uC744 \uAC78\uC694.\\n\uBD84\uC704\uAE30\uAC00
    \uC548 \uC88B\uC544\uC694."
  - "\uC5EC\uAE38 \uB4E4\uC5B4\uC624\uC2E0 \uAC70\uBA74\\n\uAC70\uB300\uD55C \uBCD1\uAE30\uB97C
    \uBCF8 \uC801 \uC788\uC8E0?"
  - "\uC544\uB9C8 \uB2F9\uC2E0\uC774 \uBC15\uC0B4\uB0B4\uC9C0\\n\uC54A\uC558\uC744\uAE4C
    \uC2F6\uC740\uB370."
  - "\uC624\uD30C\uB2D8\uC774\uB77C\uACE0 \uD574\uC694.\\n\uAF64 \uD765\uBBF8\uB86D\uAC8C
    \uC0DD\uACBC\uC8E0?"
  - "\uB808\uD14C \uC0DD\uBA85\uCCB4\uB294 \uC54C\uC544\uC694?\\n\uBCF4\uB78F\uBE5B
    \uB808\uD2F0\uCF58\uB4E4."
  - "\uC81C\uAC00 \uB108\uBB34 \uBB34\uC2DC\uD588\uB098\uC694?\\n\uD558\uC5EC\uD2BC
    \uC624\uD30C\uB2D8\uC740 \uB808\uD2F0\uCF58\uC5D0\uAC8C\uC11C\\n\uBAA8\uD2F0\uD504\uB97C
    \uC0BC\uC558\uC5B4\uC694."
  - "\uC0DD\uAE34 \uAC74 \uB2E4\uB974\uC9C0\uB9CC...\\n\uACE8\uACE0\uB2E4\uB77C\uB294
    \uC774\uB984\uC758\\n\uACE0\uC704\uD5D8\uAD70 \uB808\uD2F0\uCF58\uC774\uC8E0."
  - "\uC65C \uC774\uB7F0 \uC598\uAE30\uB97C \uD558\uB294 \uC9C0\\n\uB300\uCDA9 \uC9D0\uC791\uC774
    \uAC00\uC2DC\uC8E0?"
  - "\uB098\uD0C0\uB0AC\uB2E4\uB294 \uB9D0\uC774\uC8E0.\\n\uB808\uD2F0\uCF58\uC740
    \uC21C\uB3C4 \uB192\uC740\\n\uB808\uD14C \uD30C\uD3B8\uC5D0 \uBAA8\uC774\uC8E0."
  - "\uB2F9\uC2E0 \uBAA9\uC801\uC774 \uADF8 \uB808\uD14C\uB77C\uBA74\\n\uC544\uB9C8
    \uB9C8\uC8FC\uD558\uAC8C \uB420 \uAC70\uC608\uC694."
  - "\uC65C \uC774\uB7F0 \uAC78 \uB9D0\uD574\uC8FC\uB0D0\uACE0\uC694?\\n\uBB58 \uBB3B\uB098\uC694?\\n\uC8FD\uC9C0
    \uB9D0\uB77C\uB294 \uAC70\uC8E0."
  - "\uC2DC\uBBAC\uB7EC\uAC00 \uC2F8\uC6B0\uB294 \uBAA8\uC2B5\uC744\\n\uBCF4\uB294
    \uAC78 \uC88B\uC544\uD558\uAC70\uB4E0\uC694."
  - "\uBB50, \uC544\uB9C8 \uC624\uB294 \uB3D9\uC548\\n\uC800\uD76C \uC81C\uAD6D\uACFC\uB3C4
    \uC218 \uC5C6\uC774\\n\uBD80\uB52A\uD614\uACA0\uC8E0."
  - "\uB531\uD788 \uC801\uAC1C\uC2EC\uC740 \uC5C6\uC5B4\uC694.\\n\uAC10\uC815\uC774
    \uAC1C\uC870\uB41C \uAC78 \uB5A0\uB098\uC11C\\n\uB531\uD788 \uB3D9\uB8CC\uAC00
    \uB2F9\uD55C \uAC83\uB3C4 \uC544\uB2C8\uACE0."
  - "\uD669\uC81C \uD3D0\uD558\uB97C \uC704\uD574 \uC2F8\uC6B0\uB294\\n\uBA85\uC608\uB97C
    \uAC16\uACE0 \uB2F9\uC2E0 \uD558\uB098\\n\uBABB \uC7A1\uC544\uC11C \uC8FD\uB294\uB2E4\uBA74\\n\uC560\uCD08\uBD80\uD130
    \uADF8\uB987\uC774 \uC544\uB2CC \uAC70\uC8E0."
  - "\uADF8\uB9AC\uACE0 \uC774\uACF3\uC5D0 \uC788\uB294 \uD55C\\n\uB2F9\uC2E0\uC740
    \uC81C\uAD6D\uAD70\uC774\uB4E0 \uB9BC\uBCF4 \uCABD\uC774\uB4E0\\n\uBD80\uB52A\uD790
    \uAC70\uC608\uC694."
  - "\uB808\uD14C\uAC00 \uC788\uB294 \uAD6C\uC5ED\uC5D0\uC11C\uC758\\n\uC2DC\uBBAC\uB7EC
    \uC2E0\uD638\uB294 \uADF8 \uBB34\uC5C7\uBCF4\uB2E4\\n\uC704\uD5D8\uD55C \uC9D5\uC870\uB2C8\uAE4C."
  - "\uBA85\uB839\uB9CC \uC788\uB2E4\uBA74 \uC800\uB3C4\\n\uCC38\uC804\uD558\uACE0
    \uC2F6\uB124\uC694.\\n\uC2DC\uBBAC\uB7EC\uB97C \uC8FD\uC5EC\uBCF8 \uAC74\\n142\uB144
    \uC804\uC774 \uB9C8\uC9C0\uB9C9\uC774\uAC70\uB4E0\uC694."
  - "\uC544, \uC2DC\uAC04\uC774 \uBC8C\uC368 \uC774\uB807\uAC8C \uB410\uB098\uC694?\\n\uC804
    \uB2E4\uB978 \uD638\uCD9C\uC774 \uC788\uC5B4\uC11C \uC774\uB9CC.\\n\uAC70\uB798\uD560
    \uAC8C \uC0DD\uAE30\uBA74 \uADF8 \uB54C \uB610 \uBCF4\uC8E0."
  - "[ \uD1B5\uC2E0\uC774 \uC885\uB8CC \uB418\uC5C8\uC2B5\uB2C8\uB2E4. ]"
  gambling:
  - "\uC2DC\uBBAC\uB7EC\uB294 \uC548\uBAA9\uC774\\n\uC88B\uB2E4 \uB4E4\uC5C8\uC5B4\uC694.\\n\uBB3C\uB860
    \uB208\uC740 \uAC00\uC9C0\uACE0\\n\uACC4\uC2DC\uC9C0 \uC54A\uC9C0\uB9CC."
  repair:
  - "\uC27D\uC744 \uAF64 \uD5D8\uD558\uAC8C \uB2E4\uB8E8\uC2DC\uB124\uC694.\\n\uD558\uC9C0\uB9CC
    \uC81C\uAD6D\uC758 \uAE30\uC220\uC740 \uAC10\uB2F9 \uAC00\uB2A5\uD574\uC694."
  firstshops:
  - "\uBC18\uAC00\uC6CC\uC694.\\n\uB9C8\uC5D0\uC2A4\uD2B8\uB85C\uAC00 \uC774\uB7F0
    \uBCC0\uACBD\uAE4C\uC9C0\uB294\\n\uBB34\uC2A8 \uC77C\uB85C?"
  buyScrap:
  - "\uC2DC\uBBAC\uB7EC\uAC00 \uC791\uC5C5\uD558\uB294 \uBC29\uC2DD\uC5D0\uB294 \uD765\uBBF8
    \uC788\uC5B4\uC694."
