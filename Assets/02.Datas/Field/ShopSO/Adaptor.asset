%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 53a271983285ce0499ac617374539b78, type: 3}
  m_Name: Adaptor
  m_EditorClassIdentifier: Assembly-CSharp::ShopSO
  NPCName: "\uC5B4\uB2F5\uD130"
  Npc: 2
  dialogue:
  - "\uAD70\uC218\uD488\uC744 \uD568\uBD80\uB85C \uB0B4\uC904 \uC21C \uC5C6\uC9C0.\\n\uB0B4\uAE30\uB97C
    \uD558\uC790\uACE0."
  - "\uB9BC\uBCF4 \uAD70 \uC218\uC6A9\uC18C \uD2B9\uC18D \uC81C 32-3\\n\uD2B9\uC218\uAD70\uC218\uBC18
    \uBC18\uC7A5 \uC5B4\uB2F5\uD130 \uC0C1\uC0AC\uB2E4."
  - "\uC694\uC998 \uC678\uC6B0\uC8FC\uC5D0\uC11C \uC2DC\uBBAC\uB7EC\uAC00\\n\uC790\uC8FC
    \uCC3E\uB294\uAD70. \uC65C\uC9C0?\\n\uC5B4\uCC28\uD53C \uB108\uD76C\uB294 \uB2E4\uB978
    \uB808\uD14C\uB3C4\\n\uCDA9\uBD84\uD788 \uAC00\uCE58 \uC788\uC9C0 \uC54A\uB098?"
  - "\uB808\uD2F0\uCF58\uC774 \uB4DD\uC2E4\uAC70\uB9AC\uB294\\n\uC57C\uC0DD \uB808\uD14C\uB97C
    \uAD73\uC774?"
  - "\uC790\uC0B4\uC774\uB098 \uC0B4\uC721\uC774\\n\uBAA9\uC801\uC774 \uC544\uB2C8\uB77C\uBA74
    \uC18C\uC18D \uC5C6\uB294\\n\uC2DC\uBBAC\uB7EC\uAC00 \uAD73\uC774 \uBD84\uC7C1
    \uAD6C\uC5ED\uAE4C\uC9C0\\n \uCC3E\uC544\uC624\uB294 \uC774\uC720\uAC00 \uAD81\uAE08\uD558\uAD70."
  - "\uD760. \uC5ED\uC2DC \uB9D0\uD574\uC904 \uC0DD\uAC01\uC740 \uC5C6\uB098."
  - "\uC2DC\uBBAC\uB7EC\uB294 \uC2E0\uB8B0\uD558\uAE30 \uC88B\uC740 \uAC70\uB798\uCC98\uB2E4.\\n\uC8FD\uC9C0
    \uB9C8\uB77C."
  - "\uBE14\uB8E8 \uC2A4\uD31F\uC5D0 \uC9C4\uC785 \uD588\uC73C\uBA74\\n\uC774\uBBF8
    \uACAA\uC5C8\uACA0\uC9C0\uB9CC, \uC9C4\uC785\uC744 \uB9C9\uACE0\\n\uB300\uAE30\uD558\uB294
    \uAC15\uC801\uB4E4\uC774 \uC788\uB2E4."
  - "\uAC00\uC7A5 \uC548\uC804\uD55C \uC7A5\uC18C\uB85C\\n\uAC00\uAE30 \uC704\uD574\uC120
    \uC9C1\uC811 \uC704\uD5D8\uC73C\uB85C\\n\uAC00\uC57C \uD55C\uB2E4\uB294 \uAC8C
    \uC544\uC774\uB7EC\uB2C8\uC9C0."
  - "\uAF2D \uC2F8\uC6B8 \uD544\uC694\uB294 \uC5C6\uB2E4.\\n\uB3C4\uB9DD\uB3C4 \uD558\uB098\uC758
    \uC804\uB7B5\uC774\uB2C8\uAE4C."
  - "\uBAA9\uC801? \uB2E4\uC591\uD558\uC9C0.\\n\uC57D\uD0C8, \uAC80\uBB38, \uC18C\uD0D5.\\n\uC774\uACF3\uC5D0\uC11C
    \uB124\uAC00 \uB204\uAD6C\uC778\uC9C0\\n\uAD81\uAE08\uD574 \uD558\uB294 \uC77C\uC740
    \uB4DC\uBB3C\uB2E4."
  - "\uC774\uACF3\uC5D0\uC11C\uB294 \uC624\uB85C\uC9C0\\n\uC774\uD574\uB4DD\uC2E4\uB9CC
    \uC788\uB2E4.\\n\uB2F9\uC7A5 \uB124\uAC00 \uB9BC\uBCF4\uC758 \uB808\uD14C\uB97C
    \uCDE8\uD558\uBA74\\n\uB0B4\uAC00 \uB110 \uB9C9\uC544\uC11C\uAC8C \uB420 \uC9C0\uB3C4
    \uBAA8\uB974\uC9C0."
  - "\uC774\uB7F0, \uBC8C\uC368 \uC2DC\uAC04\uC774 \uC774\uB807\uAC8C \uB410\uB098.\\n\uAE09\uD55C
    \uC77C\uC774 \uC788\uC73C\uB2C8 \uAC70\uB798\uAC00 \uC788\uB2E4\uBA74\\n\uB2E4\uC2DC
    \uD638\uCD9C\uD574\uB77C. \uC751\uD574\uC8FC\uC9C0."
  - "[ \uD1B5\uC2E0\uC774 \uC885\uB8CC \uB418\uC5C8\uC2B5\uB2C8\uB2E4. ]"
  gambling:
  - "\uD06C\uB808\uB527\uB9CC \uCDA9\uBD84\uD558\uB2E4\uBA74 \uC6D0\uD558\uB294\\n\uBB3C\uAC74\uC744
    \uCC3E\uC744 \uC218\uB3C4 \uC788\uC744 \uAC70\uB2E4."
  repair:
  - "\uC774 \uC6B0\uC8FC\uC5D0\uC120 \uC27D\uC758 \uAD00\uB9AC\uAC00\\n\uCD5C\uC6B0\uC120\uC774\uC9C0.
    \uC88B\uC740 \uC0DD\uAC01\uC774\uB2E4."
  firstshops:
  - "\uC6A9\uCF00 \uC774\uACF3\uAE4C\uC9C0 \uC624\uB294\\n\uC2DC\uBBAC\uB7EC \uC6A9\uBCD1\uC774
    \uC788\uAD70.\\n\uC88B\uC740 \uBB3C\uAC74\uB4E4\uC774 \uC788\uB2E4.\\n\uBB3C\uB860
    \uACF5\uC9DC\uB294 \uC544\uB2C8\uC9C0\uB9CC."
  buyScrap:
  - "\uC2DC\uBBAC\uB7EC\uB4E4\uC774 \uC9C0\uD718\uD558\uB294 \uC791\uC5C5\uC7A5\uC740
    \uC720\uBA85\uD558\uC9C0\uB9CC \uBCF4\uAE30 \uC27D\uC9C0 \uC54A\uC9C0. \uAC70\uAE30\uC5D0
    \uB3C4\uC6C0\uC744 \uC904 \uC218 \uC788\uB2E4\uB2C8 \uC601\uAD11\uC774\uAD70."
