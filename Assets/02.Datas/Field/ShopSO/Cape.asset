--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 53a271983285ce0499ac617374539b78, type: 3}
  m_Name: Cape
  m_EditorClassIdentifier: Assembly-CSharp::ShopSO
  NPCName: "\uCF00\uC774\uD504"
  Npc: 1
  dialogue:
  - "\uC218\uB9AC? \uB3C4\uBC15?\\n\uBB50\uB4E0 \uB9D0\uD574."
  - "\uB0B4 \uC774\uB984? \uACE7 \uC8FD\uC744 \uC0AC\uB78C\u2026\\n\uC544\uB2C8,
    \uC0AC\uB78C \uB9DE\uB098?\\n\uD558\uC5EC\uD2BC \uC54C\uC544\uC11C \uBB50\uD558\uB824\uACE0."
  - "\uB108 \uAC19\uC740 \uC871\uC18D\uB3C4 \uC678\uB85C\uC6C0\uC744 \uD0C0\uB098?\\n\uBA3C\uC800
    \uB9D0\uC744 \uAC70\uB294 \uC2DC\uBBAC\uB7EC\uB294 \uB4DC\uBB3C\uB358\uB370."
  - "\uC548 \uADF8\uB798\uB3C4 \uC81C\uAD6D \uCABD \uAD11\uC2E0\uB3C4\uB791\\n\uB9BC\uBCF4
    \uCABD \uAD70\uBC14\uB9AC \uB54C\uBB38\uC5D0\\n\uC815\uC2E0\uC774 \uC5C6\uC5B4."
  - "\uB108\uD76C \uC2DC\uBBAC\uB7EC\uB4E4\uC740 \uC5B4\uCC28\uD53C\\n\uB2E4\uB978
    \uC139\uD130\uC758 \uB808\uD14C\uB3C4 \uC27D\uAC8C \uC5BB\uC796\uC544?\\n\uBB50
    \uD558\uB7EC \uC774\uB7F0 \uBCC0\uBC29\uAE4C\uC9C0\\n\uCC3E\uC544\uC624\uB294
    \uAC70\uC57C?"
  - "\uBB50, \uB108\uB3C4 \uC0AC\uC815\uC774 \uC788\uACA0\uC9C0.\\n\uC81C \uBA85\uC5D0
    \uBABB \uC8FD\uB294 \uB188\uB4E4\uC774\\n\uBB34\uC2A8 \uC695\uC2EC\uC774 \uC788\uACA0\uC5B4."
  - "\uBC1C\uCE78 \uC560\uB4E4\uD55C\uD14C \uB0B4 \uC774\uB984\uC744\\n\uB9D0\uD574\uBD24\uC790
    \uC544\uBB34 \uB4DD\uB3C4 \uC5C6\uC744 \uAC78?\\n\uB124 \uC5B4\uD56D\uC744 \uAE68\uC11C
    \uB1CC \uC9F8\uB85C\\n\uB098\uD55C\uD14C \uAC00\uC838\uC624\uB294 \uB188\uC740
    \uC788\uACA0\uC9C0\uB9CC."
  - "\uADF8 \uB54C\uB294 \uBE44\uC2F8\uAC8C \uCCD0\uC904\uAC8C.\\n\uC2DC\uBBAC\uB7EC
    \uB1CC\uB294 \uAC00\uCE58\uAC00 \uD06C\uAC70\uB4E0."
  - "\uB09C \uB108\uD55C\uD14C \uB354 \uC774\uC0C1\\n\uD574\uC904 \uB9D0\uC774 \uC5C6\uC5B4."
  - "...\uB09C \uB9D0\uC8FC\uBCC0\uC774 \uBCC4\uB85C \uC5C6\uC5B4.\\n\uB2E4\uB978
    \uC0AC\uB78C\uC744 \uCC3E\uC544\uBD10."
  - "[ \uD1B5\uC2E0\uC774 \uC885\uB8CC \uB418\uC5C8\uC2B5\uB2C8\uB2E4. ]"
  gambling:
  - "\uD589\uC6B4\uC744 \uBE4C\uAC8C. \uBBF8\uC548\uD558\uC9C0\uB9CC\\n\uC774\uACF3
    \uB8F0\uC774\uB77C\uC11C \uB9D0\uC774\uC57C."
  repair:
  - "\uAF64 \uD5D8\uD55C \uC77C\uC744 \uACAA\uC5C8\uB098 \uBCF8 \uB370?"
  firstshops:
  - "\uC774 \uC9C0\uC625\uAE4C\uC9C0 \uAC78\uC5B4 \uB4E4\uC5B4\uC628 \uB188\uC774\\n\uB204\uAD70\uAC00
    \uD588\uB354\uB2C8 \uC2DC\uBBAC\uB7EC\uC778\uAC00."
  buyScrap:
  - "\uC2DC\uBBAC\uB7EC\uB4E4\uC740 \uBB58 \uB9CC\uB4E4 \uBAB8\uB3C4 \uC5C6\uC73C\uBA74\uC11C
    \uD56D\uC0C1 \uB69D\uB531 \uC798 \uB9CC\uB4E4\uC5B4\uB0B8\uB2E8 \uB9D0\uC774\uC9C0."
