  m_Script: {fileID: 11500000, guid: 53a271983285ce0499ac617374539b78, type: 3}
  m_Name: Cape 3
  m_EditorClassIdentifier: Assembly-CSharp::ShopSO
  NPCName: "\uCF00\uC774\uD5043"
  Npc: 5
  dialogue:
  - "\uC544\uBB34\uB9AC \uC2DC\uBBAC\uB7EC\uB77C\uC9C0\uB9CC\\n\uC740\uD3D0\uC7A5\uB3C4
    \uC5C6\uC774 \uB2F9\uB2F9\uD558\uAC8C\\n\uC5EC\uAE30\uAE4C\uC9C0 \uC628\uB2E4\uACE0?"
  - "\uC8FD\uACE0 \uC2F6\uC5B4\uC11C\\n\uD658\uC7A5\uD588\uAD6C\uB098 \uB108."
  - "\uC65C \uB0B4 \uC8FC\uBCC0\uC5D4\\n\uC774\uB7F0 \uB188\uB4E4\uB9CC \uAF2C\uC774\uB294
    \uAC70\uC9C0?"
  - "\uADF8\uB0E5 \uC801\uB2F9\uD788 \uD574\uC801\uC774\uB098/n\uC7A1\uB294 \uC6A9\uBCD1\uC73C\uB85C
    \uC0B4 \uAC83\uC774\uC9C0."
  - "\uC815\uC81C\uB3C4, \uC815\uD654\uB3C4 \uC548\uB41C\\n\uCE68\uC2DD \uB369\uC5B4\uB9AC\uB97C
    \uAC00\uC9C0\uACA0\uB2E4\uACE0?"
  - "\uBB50, \uC6B0\uB9AC?"
  - "\uB2F9\uC7A5 \uC6B0\uB9AC \uBC1C\uCE78\uB9CC \uD574\uB3C4\\n\uC21C\uC218 \uB808\uD14C\uAC00
    \uC788\uB294 \uC139\uD130\uB85C\uB294\\n\uC811\uADFC \uC870\uCC28 \uC548 \uD574."
  - "\uC81C\uAD6D \uC0AC\uC774\uBE44\uB791 \uAD70\uBC14\uB9AC\uB4E4\uC774\uB77C\uACE0
    \uB2E4\uB97C \uAC83 \uAC19\uC544?"
  - "\uADF8 \uB188\uB4E4\uB3C4 \uCD5C\uB300\uD55C \uC548\uC804 \uAC70\uB9AC \uB0B4\uC5D0\uC11C\\n\uCF69\uACE0\uBB3C\uC774\uB098
    \uC8FC\uC6CC\uBA39\uB294 \uC2E0\uC138\uB77C\uACE0."
  - "\uB204\uAD70\uAC00\uD55C\uD14C \uC774\uC6A9\uB2F9\uD558\uACE0 \uC788\uB294 \uAC70\uB77C\uBA74..."
  - ...
  - "\uC544\uB0D0, \uB410\uC5B4."
  - "\uC2DC\uBBAC\uB7EC\uC796\uC544. \uC2A4\uC2A4\uB85C \uD574\uACB0\uD574\uC57C\uC9C0."
  - "\uB098\uD55C\uD14C \uAFB8\uC900\uD788 \uC774\uC57C\uAE30 \uAC70\uB294 \uB188\uC740\\n\uC774
    \uC6B0\uC8FC\uC5D0\uC11C \uBCC4\uB85C \uC5C6\uC5B4."
  - "\uADF8\uB7F0 \uB140\uC11D\uC774 \uB0B4 \uAD6C\uC5ED\uC5D0\uC11C \uAC1D\uC0AC\uD558\uBA74\\n\uB098\uB3C4
    \uAFC8\uC790\uB9AC\uAC00 \uB4A4\uC22D\uC22D\uD558\uB2C8\uAE4C."
  - ...
  - ......
  - "\uC8FD\uC9C0 \uB9D0\uB77C\uB294 \uC598\uAE30\uC57C."
  gambling:
  - "\uADF8\uB798\uB3C4 \uACF5\uC9DC\uB85C \uC904 \uC218\uB294 \uC5C6\uC5B4. \uBBF8\uC548."
  repair:
  - "\uC8FD\uC9C0 \uB9D0\uB77C\uACE0."
  firstshops:
  - "\uB108... \uB10C \uC815\uB9D0 \uBBF8\uCCE4\uB124. \uACB0\uAD6D \uC5EC\uAE30\uAE4C\uC9C0
    \uC628 \uAC70\uC57C?"
  buyScrap:
  - "\uC2DC\uBBAC\uB7EC\uB4E4\uC740 \uBB58 \uB9CC\uB4E4 \uBAB8\uB3C4 \uC5C6\uC73C\uBA74\uC11C
    \uD56D\uC0C1 \uB69D\uB531 \uC798 \uB9CC\uB4E4\uC5B4\uB0B8\uB2E8 \uB9D0\uC774\uC9C0."
